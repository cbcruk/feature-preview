{
  "name": "feature-preview",
  "version": "0.0.0",
  "description": "localStorage-backed feature preview for web clients — see finished-but-unreleased work in any deployed environment, no redeploy. Zero dependencies.",
  "keywords": [
    "feature-flags",
    "feature-preview",
    "localStorage",
    "typescript",
    "zero-dependency"
  ],
  "homepage": "https://github.com/cbcruk/feature-preview#readme",
  "bugs": {
    "url": "https://github.com/cbcruk/feature-preview/issues"
  },
  "license": "MIT",
  "author": "Eunsoo Lee <cbcruk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbcruk/feature-preview.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "default": "./dist/react.mjs"
    },
    "./panel": {
      "types": "./dist/panel.d.mts",
      "default": "./dist/panel.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.10.0"
}
